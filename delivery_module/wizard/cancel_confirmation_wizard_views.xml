<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cancel_confirmation_wizard_form" model="ir.ui.view">
        <field name="name">cancel.confirmation.wizard.form</field>
        <field name="model">cancel.confirmation.wizard</field>
        <field name="arch" type="xml">
            <form string="İptal Onayı">
                <group>
                    <field name="delivery_id" invisible="1"/>
                    <field name="message" readonly="1"/>
                </group>
                <footer>
                    <button name="action_confirm_cancel" string="Evet, İptal Et" type="object" class="btn-danger"/>
                    <button string="Hayır, Vazgeç" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
