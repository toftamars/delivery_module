<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_capacity_control_wizard_form" model="ir.ui.view">
        <field name="name">capacity.control.wizard.form</field>
        <field name="model">capacity.control.wizard</field>
        <field name="arch" type="xml">
            <form string="Kapasite Kontrol">
                <sheet>
                    <div class="oe_title">
                        <h1>Kapasite Kontrol Sistemi</h1>
                    </div>
                    <group>
                        <group string="Tarih Seçimi">
                            <field name="date" widget="date" options="{'format': 'dd/mm/yyyy'}" placeholder="Tarih seçin..."/>
                        </group>
                        <group string="Araç Seçimi">
                            <field name="vehicle_id" placeholder="Araç seçin..."/>
                        </group>
                    </group>
                    <group string="Sonuç" attrs="{'invisible': [('result', '=', False)]}">
                        <field name="result" readonly="1" widget="text" placeholder="Kapasite sorgulaması yapmak için tarih ve araç seçin, ardından 'Kapasite Sorgula' butonuna tıklayın."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_query_capacity" string="Kapasite Sorgula" type="object" class="btn-primary" icon="fa-search"/>
                    <button string="Kapat" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
